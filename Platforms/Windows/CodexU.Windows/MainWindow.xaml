<Window x:Class="CodexU.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CodexU.Windows.Controls"
        Title="codexU"
        Width="820"
        Height="720"
        MinWidth="820"
        MaxWidth="820"
        MinHeight="620"
        MaxHeight="920"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="{Binding IsPinnedTopmost}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        Closed="Window_Closed">
  <Window.Resources>
    <controls:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <controls:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <controls:TaskKindBrushConverter x:Key="TaskKindBrushConverter" />
    <controls:ResourceKeyBrushConverter x:Key="ResourceKeyBrushConverter" />

    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style x:Key="SectionBorderStyle" TargetType="Border">
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background" Value="{DynamicResource SectionBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SectionStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="ElevatedCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
      <Setter Property="Padding" Value="8" />
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SurfaceTrackBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Opacity" Value="0.75" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SmallComboStyle" TargetType="ComboBox">
      <Setter Property="Height" Value="28" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeBrush}" />
    </Style>
  </Window.Resources>

  <Border x:Name="WindowChrome"
          Margin="10"
          CornerRadius="24"
          Background="{DynamicResource WindowBrush}"
          BorderBrush="{DynamicResource WindowStrokeBrush}"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.20" />
    </Border.Effect>

    <Grid Margin="16,14,16,14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,9,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1F59ED" Offset="0" />
                <GradientStop Color="#4778FB" Offset="0.42" />
                <GradientStop Color="#A195F4" Offset="0.72" />
                <GradientStop Color="#DAA3FA" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="U"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="codexU"
                     FontSize="22"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <ComboBox Grid.Column="2"
                  Width="82"
                  Margin="0,0,8,0"
                  Style="{StaticResource SmallComboStyle}"
                  ItemsSource="{Binding ThemeOptions}"
                  DisplayMemberPath="Label"
                  SelectedValuePath="Value"
                  SelectedValue="{Binding ThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="Appearance" />
        <ComboBox Grid.Column="3"
                  Width="64"
                  Margin="0,0,8,0"
                  Style="{StaticResource SmallComboStyle}"
                  ItemsSource="{Binding LanguageOptions}"
                  DisplayMemberPath="Label"
                  SelectedValuePath="Value"
                  SelectedValue="{Binding Language, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="Language" />
        <Border Grid.Column="4"
                Height="28"
                MinWidth="58"
                Margin="0,0,8,0"
                CornerRadius="14"
                Background="{DynamicResource ControlBrush}"
                BorderBrush="{DynamicResource ControlStrokeBrush}"
                BorderThickness="1"
                Padding="10,0">
          <TextBlock Text="{Binding PlanLabel}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center" />
        </Border>
        <Button Grid.Column="5"
                Style="{StaticResource IconButtonStyle}"
                Command="{Binding RefreshCommand}"
                Margin="0,0,8,0"
                ToolTip="Refresh">
          <TextBlock Text="{Binding RefreshGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="12" />
        </Button>
        <Button Grid.Column="6"
                Style="{StaticResource IconButtonStyle}"
                Margin="0,0,8,0"
                ToolTip="{Binding PinTooltip}"
                Click="PinButton_Click">
          <TextBlock Text="{Binding PinGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="12" />
        </Button>
        <Button Grid.Column="7"
                Style="{StaticResource IconButtonStyle}"
                ToolTip="Close to tray"
                Click="CloseToTray_Click">
          <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
        </Button>
      </Grid>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Style="{StaticResource SectionBorderStyle}"
                  Visibility="{Binding ShowDiagnostics, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
              <Grid Margin="0,0,0,8">
                <TextBlock Text="{Binding EnvironmentTitle}" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Text="{Binding EnvironmentDetail}"
                           HorizontalAlignment="Right"
                           FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </Grid>
              <ItemsControl ItemsSource="{Binding Diagnostics}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,3">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Glyph}"
                                 FontFamily="Segoe MDL2 Assets"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Foreground="{Binding BrushKey, Converter={StaticResource ResourceKeyBrushConverter}}"
                                 VerticalAlignment="Top"
                                 Margin="0,1,0,0" />
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Detail}"
                                   FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource SectionBorderStyle}">
            <StackPanel>
              <Grid Margin="0,0,0,12">
                <TextBlock Text="{Binding UsageTitle}" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Text="{Binding UsageDetail}"
                           HorizontalAlignment="Right"
                           FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </Grid>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="160" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                  <Grid Width="146" Height="146">
                    <controls:QuotaRingControl PrimaryPercent="{Binding PrimaryRemainingPercent}"
                                               SecondaryPercent="{Binding SecondaryRemainingPercent}"
                                               HasPrimary="{Binding HasPrimaryQuota}"
                                               HasSecondary="{Binding HasSecondaryQuota}" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="5h" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandPrimaryBrush}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding PrimaryQuotaText}" FontSize="16" FontWeight="Bold" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="7d" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandSecondaryBrush}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding SecondaryQuotaText}" FontSize="16" FontWeight="Bold" />
                      </StackPanel>
                      <TextBlock Text="{Binding QuotaLeftLabel}"
                                 FontSize="10"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                  </Grid>

                  <Grid Width="154" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="5" Height="5" Fill="{DynamicResource BrandPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="5h" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource BrandPrimaryBrush}" Margin="5,0" />
                    <TextBlock Grid.Column="2" Text="{Binding PrimaryResetText}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" />
                    <Ellipse Grid.Row="1" Width="5" Height="5" Fill="{DynamicResource BrandSecondaryBrush}" VerticalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="7d" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource BrandSecondaryBrush}" Margin="5,4,5,0" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SecondaryResetText}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                  </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                  <UniformGrid Columns="3" Margin="0,0,0,12">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                      <StackPanel>
                        <Grid>
                          <TextBlock Text="{Binding TodayTitle}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding TodayCostText}" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding TodayTokensText}" FontSize="21" FontWeight="Bold" Margin="0,6,0,7" />
                        <controls:TokenSplitBarControl Height="8" UncachedInput="{Binding TodayUncached}" CachedInput="{Binding TodayCached}" Output="{Binding TodayOutput}" />
                        <Grid Margin="0,7,0,0">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <TextBlock Text="{Binding InputLabel}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding TodayInputText}" Grid.Row="0" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding CachedLabel}" Grid.Row="1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding TodayCachedText}" Grid.Row="1" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding OutputLabel}" Grid.Row="2" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding TodayOutputText}" Grid.Row="2" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="4,0">
                      <StackPanel>
                        <Grid>
                          <TextBlock Text="{Binding SevenDayTitle}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding SevenDayCostText}" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding SevenDayTokensText}" FontSize="21" FontWeight="Bold" Margin="0,6,0,7" />
                        <controls:TokenSplitBarControl Height="8" UncachedInput="{Binding SevenDayUncached}" CachedInput="{Binding SevenDayCached}" Output="{Binding SevenDayOutput}" />
                        <Grid Margin="0,7,0,0">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <TextBlock Text="{Binding InputLabel}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding SevenDayInputText}" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding CachedLabel}" Grid.Row="1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding SevenDayCachedText}" Grid.Row="1" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding OutputLabel}" Grid.Row="2" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding SevenDayOutputText}" Grid.Row="2" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                      </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="8,0,0,0">
                      <StackPanel>
                        <Grid>
                          <TextBlock Text="{Binding LifetimeTitle}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding LifetimeCostText}" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding LifetimeTokensText}" FontSize="21" FontWeight="Bold" Margin="0,6,0,7" />
                        <controls:TokenSplitBarControl Height="8" UncachedInput="{Binding LifetimeUncached}" CachedInput="{Binding LifetimeCached}" Output="{Binding LifetimeOutput}" />
                        <Grid Margin="0,7,0,0">
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <TextBlock Text="{Binding InputLabel}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding LifetimeInputText}" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding CachedLabel}" Grid.Row="1" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding LifetimeCachedText}" Grid.Row="1" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding OutputLabel}" Grid.Row="2" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                          <TextBlock Text="{Binding LifetimeOutputText}" Grid.Row="2" HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                      </StackPanel>
                    </Border>
                  </UniformGrid>

                  <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                      <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource StatusWarningBrush}" Margin="0,0,7,0" />
                          <TextBlock Text="{Binding ValueProgressTitle}" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                          <TextBlock Text="{Binding MonthCostText}" FontSize="16" FontWeight="Bold" />
                          <TextBlock Text="{Binding MonthCapText}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="5,5,0,0" />
                        </StackPanel>
                      </Grid>
                      <controls:ValueProgressBarControl Height="18" CurrentValue="{Binding MonthCostValue}" MaxValue="{Binding MonthMaxValue}" />
                      <Grid Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal">
                          <Ellipse Width="5" Height="5" Fill="{DynamicResource StatusInfoBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="Plus" FontSize="8.5" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,10,0" />
                          <Ellipse Width="5" Height="5" Fill="{DynamicResource BrandSecondaryBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="Pro100" FontSize="8.5" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,10,0" />
                          <Ellipse Width="5" Height="5" Fill="{DynamicResource BrandLightBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="Pro200" FontSize="8.5" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding FullQuotaText}" HorizontalAlignment="Right" FontSize="8.5" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" />
                      </Grid>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,0">
            <StackPanel>
              <Grid Margin="0,0,0,10">
                <TextBlock Text="{Binding TaskBoardTitle}" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Text="{Binding TaskBoardSummary}" HorizontalAlignment="Right" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
              </Grid>
              <ItemsControl ItemsSource="{Binding TaskColumns}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border CornerRadius="10"
                            Padding="8"
                            MinHeight="274"
                            Margin="0,0,8,0"
                            Background="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}, ConverterParameter=fill}"
                            BorderBrush="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}}"
                            BorderThickness="1"
                            Opacity="0.96">
                      <StackPanel>
                        <Grid Margin="0,0,0,8">
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IconGlyph}" FontSize="11" FontWeight="Bold" Foreground="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Count}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="6,0,0,0" />
                          </StackPanel>
                          <TextBlock Text="..." HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" />
                        </Grid>

                        <StackPanel Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVisibilityConverter}}" Height="66" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="○" FontSize="13" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiaryBrush}" />
                          <TextBlock Text="{Binding EmptyText}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Items}" Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibilityConverter}}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Style="{StaticResource ElevatedCardBorderStyle}" Margin="0,0,0,7">
                                <StackPanel>
                                  <Grid>
                                    <TextBlock Text="{Binding Code}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding RelativeTime}" HorizontalAlignment="Right" FontSize="8" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                  </Grid>
                                  <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="34" Margin="0,5,0,0" />
                                  <TextBlock Text="{Binding Detail}" FontSize="9" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                  <Grid Margin="0,6,0,0">
                                    <Border HorizontalAlignment="Left"
                                            CornerRadius="9"
                                            Padding="6,2"
                                            Background="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}, ConverterParameter=fill}">
                                      <TextBlock Text="{Binding Chip}" FontSize="9" FontWeight="Bold" Foreground="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}}" />
                                    </Border>
                                    <Border HorizontalAlignment="Right"
                                            Width="18"
                                            Height="18"
                                            CornerRadius="9"
                                            Background="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}, ConverterParameter=fill}">
                                      <TextBlock Text="{Binding Avatar}" FontSize="9" FontWeight="Bold" Foreground="{Binding Kind, Converter={StaticResource TaskKindBrushConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                  </Grid>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding OverflowText}"
                                   Visibility="{Binding HasOverflow, Converter={StaticResource BoolToVisibilityConverter}}"
                                   FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="6,0,0,0" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
        <TextBlock Text="{Binding FooterText}" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBlock Text="Ctrl+Alt+U" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
