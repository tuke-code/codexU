<Application x:Class="CodexU.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <SolidColorBrush x:Key="WindowBrush" Color="#F2F7F8FA" />
    <SolidColorBrush x:Key="WindowStrokeBrush" Color="#2A000000" />
    <SolidColorBrush x:Key="SectionBrush" Color="#80FFFFFF" />
    <SolidColorBrush x:Key="SectionStrokeBrush" Color="#12000000" />
    <SolidColorBrush x:Key="CardBrush" Color="#B8FFFFFF" />
    <SolidColorBrush x:Key="CardElevatedBrush" Color="#E8FFFFFF" />
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#14000000" />
    <SolidColorBrush x:Key="ControlBrush" Color="#8AFFFFFF" />
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#11000000" />
    <SolidColorBrush x:Key="SurfaceTrackBrush" Color="#18000000" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8000000" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#99000000" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#66000000" />
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#2866F7" />
    <SolidColorBrush x:Key="BrandStrongBrush" Color="#1F59ED" />
    <SolidColorBrush x:Key="BrandLightBrush" Color="#7BA0FF" />
    <SolidColorBrush x:Key="BrandSecondaryBrush" Color="#8B6DFF" />
    <SolidColorBrush x:Key="BrandHighlightBrush" Color="#DAA3FA" />
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#30D158" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#0A84FF" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#FF9F0A" />
    <SolidColorBrush x:Key="StatusDangerBrush" Color="#FF453A" />
    <SolidColorBrush x:Key="StatusNeutralBrush" Color="#98989D" />
    <SolidColorBrush x:Key="DataZeroBrush" Color="#5A98989D" />
    <SolidColorBrush x:Key="TaskActiveFillBrush" Color="#12FF9F0A" />
    <SolidColorBrush x:Key="TaskPendingFillBrush" Color="#1098989D" />
    <SolidColorBrush x:Key="TaskScheduledFillBrush" Color="#128B6DFF" />
    <SolidColorBrush x:Key="TaskDoneFillBrush" Color="#1230D158" />
  </Application.Resources>
</Application>
